# ─────────────────────────────────────────────────────────────────────────────
# Flux OS — variáveis de ambiente (copie para .env.local e preencha os valores)
# No Vercel: Project → Settings → Environment Variables (Production + Preview).
# NUNCA comite .env.local — só este .env.example (sem valores).
# ─────────────────────────────────────────────────────────────────────────────

# ── API-Football (api-sports.io) — dados de jogos ────────────────────────────
# Necessário para Timeline / War Room com dados reais.
# Free tier: 100 req/dia. Pegue em https://dashboard.api-football.com
FOOTBALL_API_KEY=
# Opcional — intervalo de polling em ms (default 60000)
FOOTBALL_POLL_INTERVAL=

# ── Supabase — persistência (prompts / calendário / aprovações) ───────────────
# A publishable/anon key é pública por design (protegida por RLS).
# Rode supabase/schema.sql uma vez no SQL Editor do projeto.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Meta (Instagram / Facebook) — OAuth de publicação ────────────────────────
# Meta Developer → Flux OS → App ID / App Secret.
# Cadastre o Redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/instagram/callback
# (ex.: https://fluxos-x7xi.vercel.app/api/auth/instagram/callback) em
# Facebook Login → Valid OAuth Redirect URIs.
META_APP_ID=
META_APP_SECRET=

# ── TikTok (Login Kit + Content Posting API) ──────────────────────────────────
# TikTok for Developers → app → Client key/secret. Redirect URI:
# <NEXT_PUBLIC_APP_URL>/api/auth/tiktok/callback (cadastre em Login Kit).
# Domínio precisa estar verificado (public/tiktok*.txt).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── YouTube (Google Cloud OAuth — YouTube Data API v3) ────────────────────────
# Google Cloud → Credentials → OAuth client (Web). Redirect URI:
# <NEXT_PUBLIC_APP_URL>/api/auth/youtube/callback. Ative a YouTube Data API v3.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── IA — refino de copy no Multipost ──────────────────────────────────────────
# Tier 1 (preferido): Google Gemini. Pegue em https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional — modelo Gemini (default: gemini-1.5-flash)
GEMINI_MODEL=
# Tier 2 (alta qualidade): Anthropic. Deixe em branco para usar o tier grátis.
# Pegue em https://console.anthropic.com
ANTHROPIC_API_KEY=
# Opcional — modelo (default: claude-opus-4-5)
ANTHROPIC_MODEL=
# Opcional — modelo Claude usado no copy-engine do War Room (refino "Sonnet").
# Default: COPY_SONNET_MODEL > ANTHROPIC_MODEL > 'claude-3-5-sonnet-latest'.
COPY_SONNET_MODEL=
# Tier 2 grátis/sem-key (Pollinations). 'off' desliga e usa adaptação local.
AI_FREE_TIER=
# Opcional — modelo do tier grátis (default: openai)
AI_FREE_MODEL=

# ── App ───────────────────────────────────────────────────────────────────────
# Nome do workspace exibido na UI.
NEXT_PUBLIC_WORKSPACE_NAME=
# URL pública do app (no Vercel, a URL do deploy / domínio). Dev: localhost:3100
# (porta dedicada do Flux OS, para não colidir com outros apps locais na 3000)
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ── Legado / opcional — só se usar o stream SSE com cache Upstash Redis ───────
# O War Room novo usa polling, não precisa disso. Deixe em branco se não usar.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
